UGRAPH_IMAGE=ugraph-core:local
UGRAPH_POSTGRES_DB=ugraph
UGRAPH_POSTGRES_USER=ugraph
UGRAPH_POSTGRES_PASSWORD=change-me
UGRAPH_DEPLOYMENT=growfi
UGRAPH_MANIFEST=/app/examples/growfi/subgraph.yaml
UGRAPH_CHAIN_ID=11155111
UGRAPH_RPC_URL=
UGRAPH_FROM_BLOCK=10845295
UGRAPH_TO_BLOCK=
UGRAPH_DOMAIN=ugraph.growfi.dev
DO_DNS_ZONE=growfi.dev
DO_DNS_TTL=30
NETWORK_NAME=ugraph-net
SUBNET_NAME=ugraph-subnet-us-central1
UGRAPH_LOG_SOURCE=rpc
UGRAPH_POLL_INTERVAL_MS=1000
UGRAPH_RETRY_MAX_MS=60000
UGRAPH_REORG_POLICY=rollback
UGRAPH_REORG_CHECK_DEPTH=64
UGRAPH_HISTORY_LIMIT=256
UGRAPH_MAX_BLOCK_RANGE=500
UGRAPH_RPC_RETRIES=3
UGRAPH_RPC_TIMEOUT_SECS=15
UGRAPH_SYNC_LIMIT=500
UGRAPH_API_KEY=
UGRAPH_IPFS_GATEWAY=https://ipfs.io/ipfs/
UGRAPH_IPFS_TIMEOUT_SECS=60
UGRAPH_MAX_IPFS_FILE_BYTES=26214400

# Enable the shared raw feed on larger instances:
# COMPOSE_PROFILES=feed
# UGRAPH_LOG_SOURCE=postgres-feed
